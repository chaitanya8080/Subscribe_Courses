# ===== Backend environment variables =====
# Copy this file to ".env" (and/or backend/config/config.env) and fill in real values.
# NEVER commit the real .env / config.env files.

# Server
PORT=4000

# Auth
JWT_SECRETKEY=your_jwt_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/mycourses

# SMTP (email) — e.g. Mailtrap
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass

# Cloudinary (media uploads)
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_SECRET_KEY=your_api_secret

# Sender email
MYMAIL=your_email@example.com
